OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
STORAGE_DIR=storage
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# PostgreSQL (optional — omit for file-only dev mode)
DATABASE_URL=
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_TENANT_NAME=Default Workspace
REQUIRE_API_KEY=false
BOOTSTRAP_API_KEY=

# Optional: install Tesseract OCR locally for scanned PDF imports (brew install tesseract)
REDIS_URL=redis://127.0.0.1:6379/0
QUEUE_SERVICE_URL=http://127.0.0.1:8787
INTERNAL_API_KEY=dev-internal-key-change-me
ASYNC_JOBS_ENABLED=false
DATABASE_USE_ALEMBIC=true
